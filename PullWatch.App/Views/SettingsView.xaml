<UserControl
  x:Class="PullWatch.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid Margin="36">
      <StackPanel IsEnabled="{Binding IsEditingEnabled}">
        <local:SectionCard Header="Folders">
          <StackPanel>
            <local:PathSettingRow
              Label="WoW logs directory"
              BrowseCommand="{Binding PickWowLogsDirectoryCommand}"
              CommitCommand="{Binding CommitWowLogsDirectoryCommand}"
              Error="{Binding WowLogsDirectoryError}"
              Text="{Binding WowLogsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            />
            <local:PathSettingRow
              Label="Recordings directory"
              BrowseCommand="{Binding PickRecordingsDirectoryCommand}"
              CommitCommand="{Binding CommitRecordingsDirectoryCommand}"
              Error="{Binding RecordingsDirectoryError}"
              Text="{Binding RecordingsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            />

            <TextBlock Style="{StaticResource InputLabelStyle}" Text="Managed recordings storage" />
            <CheckBox
              IsChecked="{Binding IsRecordingStorageLimitEnabled}"
              Content="Automatically delete oldest recordings when storage exceeds"
            />
            <StackPanel
              Margin="25,10,0,0"
              IsEnabled="{Binding CanConfigureRecordingStorageLimit}"
              Orientation="Horizontal"
            >
              <TextBox
                Width="100"
                InputScope="Number"
                local:TextBoxInput.AcceptsNonNegativeIntegerOnly="True"
                local:TextBoxInput.FallbackTextWhenEmpty="1"
                Text="{Binding RecordingStorageLimitInputGigabytes, UpdateSourceTrigger=PropertyChanged}"
              />
              <TextBlock
                Margin="8,8,0,0"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="GB"
              />
              <Button
                Margin="12,0,0,0"
                Command="{Binding ApplyRecordingStorageLimitCommand}"
                Content="Apply"
              />
            </StackPanel>
            <TextBlock
              Margin="0,14,0,0"
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding RecordingStorageUsageText}"
            />
            <ProgressBar
              Width="300"
              HorizontalAlignment="Left"
              Height="8"
              Margin="0,8,0,0"
              IsIndeterminate="{Binding IsRecordingStorageUsageIndeterminate, Mode=OneWay}"
              Maximum="100"
              Value="{Binding RecordingStorageUsagePercent, Mode=OneWay}"
              Visibility="{Binding IsRecordingStorageProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            >
              <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                  <Setter Property="Background" Value="{StaticResource ProgressTrackBrush}" />
                  <Setter
                    Property="BorderBrush"
                    Value="{StaticResource ProgressTrackBorderBrush}"
                  />
                  <Setter Property="BorderThickness" Value="1" />
                  <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="ProgressRoot" SnapsToDevicePixels="True">
                          <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                          />
                          <Grid Margin="1" ClipToBounds="True">
                            <Border x:Name="PART_Track" Background="Transparent" />
                            <Border
                              x:Name="PART_Indicator"
                              HorizontalAlignment="Left"
                              Background="{TemplateBinding Foreground}"
                              CornerRadius="2"
                            />
                          </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Opacity" Value="0.7" />
                          </Trigger>
                          <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ProgressRoot" Property="Opacity" Value="0.45" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRecordingStorageOverLimit}" Value="True">
                      <Setter Property="Foreground" Value="{StaticResource FailureBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ProgressBar.Style>
            </ProgressBar>
            <TextBlock
              Margin="0,8,0,0"
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding RecordingStorageStatusText}"
            />
          </StackPanel>
        </local:SectionCard>

        <local:SectionCard Header="Automatic recording">
          <StackPanel Margin="0,18,0,0">
            <CheckBox
              FontWeight="SemiBold"
              IsChecked="{Binding RecordMythicPlus}"
              Content="Mythic+"
            />
            <StackPanel Margin="25,10,0,0" IsEnabled="{Binding CanConfigureMythicPlus}">
              <TextBlock
                Margin="0,0,0,6"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="Minimum keystone level"
              />
              <TextBox
                Width="120"
                HorizontalAlignment="Left"
                InputScope="Number"
                local:TextBoxInput.AcceptsNonNegativeIntegerOnly="True"
                local:TextBoxInput.FallbackTextWhenEmpty="0"
                Text="{Binding MinimumMythicPlusKeystoneLevel, UpdateSourceTrigger=PropertyChanged}"
              />
              <TextBlock
                Margin="0,8,0,0"
                Style="{StaticResource SecondaryTextStyle}"
                Text="Set to 0 to record every Mythic+ run. Higher values record runs at that key level or above."
              />
            </StackPanel>

            <CheckBox
              Margin="0,22,0,0"
              FontWeight="SemiBold"
              IsChecked="{Binding RecordRaidEncounters}"
              Content="Raid encounters"
            />
            <StackPanel Margin="25,10,0,0" IsEnabled="{Binding CanConfigureRaidEncounters}">
              <TextBlock
                Margin="0,0,0,8"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="Difficulties"
              />
              <UniformGrid HorizontalAlignment="Left" Columns="2" Rows="2">
                <CheckBox
                  Width="150"
                  Margin="0,0,18,8"
                  IsChecked="{Binding RecordRaidFinder}"
                  Content="Raid Finder"
                />
                <CheckBox
                  Width="150"
                  Margin="0,0,18,8"
                  IsChecked="{Binding RecordNormalRaid}"
                  Content="Normal"
                />
                <CheckBox
                  Width="150"
                  Margin="0,0,18,0"
                  IsChecked="{Binding RecordHeroicRaid}"
                  Content="Heroic"
                />
                <CheckBox
                  Width="150"
                  Margin="0,0,18,0"
                  IsChecked="{Binding RecordMythicRaid}"
                  Content="Mythic"
                />
              </UniformGrid>
            </StackPanel>
          </StackPanel>
        </local:SectionCard>

        <local:SectionCard Header="Startup">
          <StackPanel>
            <CheckBox
              Margin="0,18,0,0"
              IsChecked="{Binding StartWithWindows}"
              Content="Start PullWatch when Windows starts"
            />
            <CheckBox
              Margin="0,10,0,0"
              IsChecked="{Binding StartMinimizedToTray}"
              IsEnabled="{Binding CanStartMinimizedToTray}"
              Content="Start minimized to tray when launched by Windows"
            />
          </StackPanel>
        </local:SectionCard>

        <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Video" />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Video encoding" />
              <TextBlock
                Foreground="{StaticResource PrimaryTextBrush}"
                FontSize="15"
                FontWeight="SemiBold"
                Text="{Binding VideoEncodingSummary}"
              />
              <TextBlock
                Margin="0,4,0,0"
                Style="{StaticResource SecondaryTextStyle}"
                Text="{Binding VideoEncodingStatus}"
                TextWrapping="Wrap"
              />
              <Button
                Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Command="{Binding TestVideoEncodingCommand}"
                Content="{Binding TestVideoEncodingButtonText}"
              />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Video quality" />
              <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding VideoQualityOptions}"
                SelectedValue="{Binding SelectedVideoQuality, Mode=TwoWay}"
                SelectedValuePath="Value"
              />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Frame rate" />
              <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding FrameRateOptions}"
                SelectedValue="{Binding SelectedFrameRate, Mode=TwoWay}"
                SelectedValuePath="Value"
              />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Output scaling" />
              <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding VideoScalingOptions}"
                SelectedValue="{Binding SelectedVideoScaling, Mode=TwoWay}"
                SelectedValuePath="Value"
              />
              <TextBlock
                Margin="0,10,0,0"
                Style="{StaticResource SecondaryTextStyle}"
                Text="{Binding EstimatedRecordingSize}"
                TextWrapping="Wrap"
              />
              <CheckBox
                Margin="0,18,0,0"
                IsChecked="{Binding CaptureCursor}"
                Content="Capture cursor"
              />
              <CheckBox
                Margin="0,10,0,0"
                IsChecked="{Binding ShowCaptureBorder}"
                Content="Show capture border"
              />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Audio" />
              <CheckBox
                Margin="0,18,0,0"
                IsChecked="{Binding CaptureSystemAudio}"
                Content="Capture system audio"
              />
              <CheckBox
                Margin="0,10,0,0"
                IsChecked="{Binding CaptureMicrophone}"
                Content="Capture microphone"
              />
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
