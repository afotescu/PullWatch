<UserControl x:Class="PullWatch.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Text="Settings" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="14"
                           Style="{StaticResource SecondaryTextStyle}"
                           Text="{Binding EditingStatus}" />
            </StackPanel>

            <StackPanel Grid.Row="1" IsEnabled="{Binding IsEditingEnabled}">
                <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Folders and automatic recording" />

                        <TextBlock Margin="0,18,0,6" Text="WoW logs directory" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Command="{Binding PickWowLogsDirectoryCommand}"
                                    Content="Browse" />
                            <TextBox Text="{Binding WowLogsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <TextBlock Margin="0,5,0,0"
                                   Foreground="{StaticResource FailureBrush}"
                                   Text="{Binding WowLogsDirectoryError}" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="Clear this field to stop automatic combat-log monitoring." />

                        <TextBlock Margin="0,18,0,6" Text="Recordings directory" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Command="{Binding PickRecordingsDirectoryCommand}"
                                    Content="Browse" />
                            <TextBox Text="{Binding RecordingsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <TextBlock Margin="0,5,0,0"
                                   Foreground="{StaticResource FailureBrush}"
                                   Text="{Binding RecordingsDirectoryError}" />

                        <CheckBox Margin="0,18,0,0"
                                  IsChecked="{Binding RecordMythicPlus}"
                                  Content="Record Mythic+ runs automatically" />
                        <CheckBox Margin="0,10,0,0"
                                  IsChecked="{Binding RecordRaidEncounters}"
                                  Content="Record raid encounters automatically" />
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Video" />
                            <TextBlock Margin="0,18,0,6" Text="Bitrate (Mbps)" />
                            <TextBox Text="{Binding BitrateMegabits, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,5,0,0"
                                       Foreground="{StaticResource FailureBrush}"
                                       Text="{Binding BitrateError}" />
                            <TextBlock Margin="0,18,0,6" Text="Frame rate" />
                            <TextBox Text="{Binding FrameRate, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,5,0,0"
                                       Foreground="{StaticResource FailureBrush}"
                                       Text="{Binding FrameRateError}" />
                            <CheckBox Margin="0,18,0,0"
                                      IsChecked="{Binding CaptureCursor}"
                                      Content="Capture cursor" />
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding ShowCaptureBorder}"
                                      Content="Show capture border" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Audio" />
                            <CheckBox Margin="0,18,0,0"
                                      IsChecked="{Binding CaptureSystemAudio}"
                                      Content="Capture system audio" />
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding CaptureMicrophone}"
                                      Content="Capture microphone" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Save settings" />
                <TextBlock Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding SaveMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSaveError}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FailureBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
