<UserControl
  x:Class="PullWatch.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid Margin="36">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" IsEnabled="{Binding IsEditingEnabled}">
        <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock
              Style="{StaticResource SectionTitleStyle}"
              Text="Folders and automatic recording"
            />

            <TextBlock Style="{StaticResource InputLabelStyle}" Text="WoW logs directory" />
            <DockPanel>
              <Button
                x:Name="WowLogsDirectoryBrowseButton"
                DockPanel.Dock="Right"
                Margin="10,0,0,0"
                Command="{Binding PickWowLogsDirectoryCommand}"
                Content="Browse"
              />
              <TextBox
                x:Name="WowLogsDirectoryTextBox"
                KeyDown="OnWowLogsDirectoryKeyDown"
                LostFocus="OnWowLogsDirectoryLostFocus"
                Text="{Binding WowLogsDirectory, UpdateSourceTrigger=PropertyChanged}"
              />
            </DockPanel>
            <TextBlock
              Style="{StaticResource ValidationTextStyle}"
              Text="{Binding WowLogsDirectoryError}"
            />
            <TextBlock
              Margin="0,5,0,0"
              Style="{StaticResource SecondaryTextStyle}"
              Text="Clear this field to stop automatic combat-log monitoring."
            />

            <TextBlock Style="{StaticResource InputLabelStyle}" Text="Recordings directory" />
            <DockPanel>
              <Button
                x:Name="RecordingsDirectoryBrowseButton"
                DockPanel.Dock="Right"
                Margin="10,0,0,0"
                Command="{Binding PickRecordingsDirectoryCommand}"
                Content="Browse"
              />
              <TextBox
                x:Name="RecordingsDirectoryTextBox"
                KeyDown="OnRecordingsDirectoryKeyDown"
                LostFocus="OnRecordingsDirectoryLostFocus"
                Text="{Binding RecordingsDirectory, UpdateSourceTrigger=PropertyChanged}"
              />
            </DockPanel>
            <TextBlock
              Style="{StaticResource ValidationTextStyle}"
              Text="{Binding RecordingsDirectoryError}"
            />

            <CheckBox
              Margin="0,18,0,0"
              IsChecked="{Binding RecordMythicPlus}"
              Content="Record Mythic+ runs automatically"
            />
            <CheckBox
              Margin="0,10,0,0"
              IsChecked="{Binding RecordRaidEncounters}"
              Content="Record raid encounters automatically"
            />
          </StackPanel>
        </Border>

        <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Startup" />
            <CheckBox
              Margin="0,18,0,0"
              IsChecked="{Binding StartWithWindows}"
              Content="Start PullWatch when Windows starts"
            />
            <CheckBox
              Margin="0,10,0,0"
              IsChecked="{Binding StartMinimizedToTray}"
              IsEnabled="{Binding CanStartMinimizedToTray}"
              Content="Start minimized to tray when launched by Windows"
            />
          </StackPanel>
        </Border>

        <Border Margin="0,0,0,18" Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Video" />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Video quality" />
              <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding VideoQualityOptions}"
                SelectedValue="{Binding SelectedVideoQuality, Mode=TwoWay}"
                SelectedValuePath="Value"
              />
              <TextBlock Style="{StaticResource InputLabelStyle}" Text="Frame rate" />
              <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding FrameRateOptions}"
                SelectedValue="{Binding SelectedFrameRate, Mode=TwoWay}"
                SelectedValuePath="Value"
              />
              <TextBlock
                Margin="0,10,0,0"
                Style="{StaticResource SecondaryTextStyle}"
                Text="{Binding EstimatedRecordingSize}"
                TextWrapping="Wrap"
              />
              <CheckBox
                Margin="0,18,0,0"
                IsChecked="{Binding CaptureCursor}"
                Content="Capture cursor"
              />
              <CheckBox
                Margin="0,10,0,0"
                IsChecked="{Binding ShowCaptureBorder}"
                Content="Show capture border"
              />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Audio" />
              <CheckBox
                Margin="0,18,0,0"
                IsChecked="{Binding CaptureSystemAudio}"
                Content="Capture system audio"
              />
              <CheckBox
                Margin="0,10,0,0"
                IsChecked="{Binding CaptureMicrophone}"
                Content="Capture microphone"
              />
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>

      <TextBlock Grid.Row="1" Margin="0,0,0,0" Text="{Binding SaveMessage}">
        <TextBlock.Style>
          <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsSaveError}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource FailureBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </Grid>
  </ScrollViewer>
</UserControl>
