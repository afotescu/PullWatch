<UserControl
  x:Class="PullWatch.DiagnosticsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid Margin="36">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <ItemsControl Grid.Row="0" Margin="-9,0,-9,18" ItemsSource="{Binding Sections}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <local:SectionCard Margin="9,0" Header="{Binding Title}">
              <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <TextBlock
                        Style="{StaticResource DiagnosticLabelStyle}"
                        Text="{Binding Label}"
                      />
                      <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </local:SectionCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <local:SectionCard Grid.Row="1" Header="Recent application logs">
        <TextBox
          Margin="0,15,0,0"
          Height="320"
          FontFamily="Consolas"
          IsReadOnly="True"
          Text="{Binding RecentLogs, Mode=OneWay}"
          TextWrapping="NoWrap"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="Auto"
        />
      </local:SectionCard>

      <TextBlock
        Grid.Row="2"
        Margin="0,0,0,14"
        Style="{StaticResource SecondaryTextStyle}"
        Text="Diagnostics can include local file paths, WoW window details, and recent application log messages. Review them before sharing publicly."
      />

      <StackPanel Grid.Row="3" Orientation="Horizontal">
        <Button
          Command="{Binding CopyDiagnosticsCommand}"
          Style="{StaticResource AccentButtonStyle}"
          Content="Copy diagnostics"
        />
        <Button
          Margin="10,0,0,0"
          Command="{Binding ExportDiagnosticsCommand}"
          Content="Export diagnostics"
        />
        <TextBlock
          Margin="16,0,0,0"
          VerticalAlignment="Center"
          Style="{StaticResource SecondaryTextStyle}"
          Text="{Binding ActionMessage}"
        />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
