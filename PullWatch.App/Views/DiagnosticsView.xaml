<UserControl
  x:Class="PullWatch.DiagnosticsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid Margin="36">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,18">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Margin="0,0,9,0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Combat log reader" />
            <TextBlock
              Margin="0,15,0,4"
              Style="{StaticResource DiagnosticLabelStyle}"
              Text="State"
            />
            <TextBlock Text="{Binding CombatLogState}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Active path" />
            <TextBlock Text="{Binding CombatLogPath}" TextWrapping="Wrap" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Last successful read" />
            <TextBlock Text="{Binding LastSuccessfulRead}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Last filesystem error" />
            <TextBlock Text="{Binding LastFileSystemError}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Margin="9,0,9,0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="World of Warcraft" />
            <TextBlock
              Margin="0,15,0,4"
              Style="{StaticResource DiagnosticLabelStyle}"
              Text="State"
            />
            <TextBlock Text="{Binding WowProcessState}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Process id" />
            <TextBlock Text="{Binding WowProcessId}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Window title" />
            <TextBlock Text="{Binding WowWindowTitle}" TextWrapping="Wrap" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Last process error" />
            <TextBlock Text="{Binding WowProcessError}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Margin="9,0,0,0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recorder" />
            <TextBlock
              Margin="0,15,0,4"
              Style="{StaticResource DiagnosticLabelStyle}"
              Text="State"
            />
            <TextBlock Text="{Binding RecordingState}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Owner" />
            <TextBlock Text="{Binding RecordingOwner}" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Active output path" />
            <TextBlock Text="{Binding ActiveOutputPath}" TextWrapping="Wrap" />
            <TextBlock Style="{StaticResource DiagnosticLabelStyle}" Text="Last failure" />
            <TextBlock Text="{Binding LastRecorderFailure}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Margin="0,0,0,18" Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent application logs" />
          <TextBox
            Margin="0,15,0,0"
            Height="320"
            FontFamily="Consolas"
            IsReadOnly="True"
            Text="{Binding RecentLogs, Mode=OneWay}"
            TextWrapping="NoWrap"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Auto"
          />
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="2" Orientation="Horizontal">
        <Button
          Command="{Binding CopyDiagnosticsCommand}"
          Style="{StaticResource AccentButtonStyle}"
          Content="Copy diagnostics"
        />
        <Button
          Margin="10,0,0,0"
          Command="{Binding ExportDiagnosticsCommand}"
          Content="Export diagnostics"
        />
        <TextBlock
          Margin="16,0,0,0"
          VerticalAlignment="Center"
          Style="{StaticResource SecondaryTextStyle}"
          Text="{Binding ActionMessage}"
        />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
