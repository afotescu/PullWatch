<UserControl
  x:Class="PullWatch.DiagnosticsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid Margin="36">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <ItemsControl Grid.Row="0" Margin="-9,0,-9,18" ItemsSource="{Binding Sections}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="9,0" Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title}" />
                <ItemsControl ItemsSource="{Binding Rows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel>
                        <TextBlock
                          Style="{StaticResource DiagnosticLabelStyle}"
                          Text="{Binding Label}"
                        />
                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Grid.Row="1" Margin="0,0,0,18" Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent application logs" />
          <TextBox
            Margin="0,15,0,0"
            Height="320"
            FontFamily="Consolas"
            IsReadOnly="True"
            Text="{Binding RecentLogs, Mode=OneWay}"
            TextWrapping="NoWrap"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Auto"
          />
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="2" Orientation="Horizontal">
        <Button
          Command="{Binding CopyDiagnosticsCommand}"
          Style="{StaticResource AccentButtonStyle}"
          Content="Copy diagnostics"
        />
        <Button
          Margin="10,0,0,0"
          Command="{Binding ExportDiagnosticsCommand}"
          Content="Export diagnostics"
        />
        <TextBlock
          Margin="16,0,0,0"
          VerticalAlignment="Center"
          Style="{StaticResource SecondaryTextStyle}"
          Text="{Binding ActionMessage}"
        />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
