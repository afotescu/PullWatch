<UserControl
  x:Class="PullWatch.RecordingStatusIndicator"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <Grid>
    <Ellipse
      RenderTransformOrigin="0.5,0.5"
      StrokeThickness="{Binding IndicatorStrokeThickness, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
    >
      <Ellipse.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
      </Ellipse.RenderTransform>
      <Ellipse.Style>
        <Style TargetType="Ellipse">
          <Setter Property="Fill" Value="{StaticResource StatusNeutralBrush}" />
          <Setter Property="Stroke" Value="{StaticResource BorderBrush}" />
          <Style.Triggers>
            <DataTrigger
              Binding="{Binding Health, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
              Value="{x:Static local:RecordingStatusHealth.Active}"
            >
              <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
              <Setter Property="Stroke" Value="{StaticResource HealthyBrush}" />
            </DataTrigger>
            <DataTrigger
              Binding="{Binding Health, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
              Value="{x:Static local:RecordingStatusHealth.Ready}"
            >
              <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
              <Setter Property="Stroke" Value="{StaticResource HealthyBrush}" />
            </DataTrigger>
            <DataTrigger
              Binding="{Binding Health, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
              Value="{x:Static local:RecordingStatusHealth.ManualOnly}"
            >
              <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
              <Setter Property="Stroke" Value="{StaticResource HealthyBrush}" />
            </DataTrigger>
            <DataTrigger
              Binding="{Binding Health, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
              Value="{x:Static local:RecordingStatusHealth.AttentionNeeded}"
            >
              <Setter Property="Fill" Value="{StaticResource FailureBrush}" />
              <Setter Property="Stroke" Value="{StaticResource FailureBrush}" />
            </DataTrigger>
            <DataTrigger
              Binding="{Binding IsPulseActive, RelativeSource={RelativeSource AncestorType=local:RecordingStatusIndicator}}"
              Value="True"
            >
              <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
              <Setter Property="Stroke" Value="{StaticResource HealthyBrush}" />
              <DataTrigger.EnterActions>
                <BeginStoryboard x:Name="RecordingPulseStoryboard">
                  <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation
                      Storyboard.TargetProperty="Opacity"
                      To="0.48"
                      Duration="0:0:0.75"
                    />
                    <DoubleAnimation
                      Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                      To="1.18"
                      Duration="0:0:0.75"
                    />
                    <DoubleAnimation
                      Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                      To="1.18"
                      Duration="0:0:0.75"
                    />
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <StopStoryboard BeginStoryboardName="RecordingPulseStoryboard" />
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Ellipse.Style>
    </Ellipse>
  </Grid>
</UserControl>
