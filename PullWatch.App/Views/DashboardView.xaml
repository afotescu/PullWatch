<UserControl x:Class="PullWatch.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Text="Dashboard" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="14"
                           Style="{StaticResource SecondaryTextStyle}"
                           Text="Recording status and controls" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,0,0,18"
                    Background="#392226"
                    BorderBrush="{StaticResource FailureBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Visibility="{Binding IsFailureVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource FailureBrush}"
                                   FontWeight="SemiBold"
                                   Text="Recorder needs attention" />
                        <TextBlock Margin="0,5,12,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding FailureMessage}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding DismissFailureCommand}"
                            Content="Dismiss" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,18"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="RECORDING STATUS" />
                        <TextBlock Margin="0,7,0,0"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Text="{Binding StateTitle}" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="14"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding StateDescription}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="28,0,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="Duration" />
                        <TextBlock Margin="0,5,0,0"
                                   FontFamily="Consolas"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="{Binding Duration}" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="Activity" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding RecordingDetail}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding RecordingDetail}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="Output path" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="14"
                                       Text="{Binding OutputPath}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding OutputPath}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="0,28,0,0"
                                Orientation="Horizontal">
                        <Button Command="{Binding ManualRecordingCommand}"
                                Content="{Binding ManualRecordingButtonText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsManualStopMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource FailureBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource FailureBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="10,0,0,0"
                                Command="{Binding OpenRecordingsFolderCommand}"
                                Content="Open recordings folder" />
                        <TextBlock Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding CommandMessage}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,0,0,18"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="Recordings" />
                            <TextBlock Margin="0,6,12,0"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="{Binding RecordingLibraryStatus}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Command="{Binding RefreshRecordingsCommand}"
                                Content="Refresh" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Command="{Binding OpenRecordingsFolderCommand}"
                                Content="Open folder" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"
                                 MinHeight="320"
                                 Margin="0,0,18,0"
                                 Background="{StaticResource SurfaceRaisedBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 ItemsSource="{Binding Recordings}"
                                 SelectedItem="{Binding SelectedRecording, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DisplayName}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Style="{StaticResource SecondaryTextStyle}"
                                                   Text="{Binding Detail}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="Transparent"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder"
                                                                Property="Background"
                                                                Value="#343B45" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder"
                                                                Property="Background"
                                                                Value="#3A3024" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    MinHeight="320"
                                    Background="#111318"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <MediaElement x:Name="RecordingPlayer"
                                                  LoadedBehavior="Manual"
                                                  MediaEnded="OnPlayerMediaEnded"
                                                  MediaFailed="OnPlayerMediaFailed"
                                                  MediaOpened="OnPlayerMediaOpened"
                                                  Stretch="Uniform"
                                                  UnloadedBehavior="Stop" />
                                    <TextBlock x:Name="PlayerPlaceholder"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Style="{StaticResource SecondaryTextStyle}"
                                               Text="{Binding RecordingLibraryStatus}"
                                               TextAlignment="Center"
                                               Visibility="{Binding IsPlayerPlaceholderVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="PlayPauseButton"
                                        Grid.Column="0"
                                        MinWidth="72"
                                        Click="OnPlayPauseClicked"
                                        Content="Play"
                                        IsEnabled="False" />
                                <TextBlock x:Name="CurrentTimeText"
                                           Grid.Column="1"
                                           Margin="12,0,10,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           Style="{StaticResource SecondaryTextStyle}"
                                           Text="00:00" />
                                <Slider x:Name="PlaybackSlider"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        IsEnabled="False"
                                        Maximum="0"
                                        Minimum="0"
                                        PreviewMouseDown="OnPlaybackSliderPreviewMouseDown"
                                        PreviewMouseUp="OnPlaybackSliderPreviewMouseUp"
                                        ValueChanged="OnPlaybackSliderValueChanged" />
                                <TextBlock x:Name="DurationText"
                                           Grid.Column="3"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           Style="{StaticResource SecondaryTextStyle}"
                                           Text="00:00" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,9,0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Combat log" />
                        <TextBlock Margin="0,13,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding CombatLogHealth}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CombatLogHealth}" Value="Monitoring">
                                            <Setter Property="Foreground" Value="{StaticResource HealthyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding CombatLogDetail}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CombatLogDetail}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="9,0,0,0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Recorder" />
                        <TextBlock Margin="0,13,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding RecorderHealth}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource HealthyBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecorderHealth}" Value="Attention needed">
                                            <Setter Property="Foreground" Value="{StaticResource FailureBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecorderHealth}" Value="Idle">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding RecorderDetail}" />
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding RecordingStatistics}"
                                   ToolTip="Expected counts accepted recording requests. Saved counts recordings finalized successfully." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
