<UserControl x:Class="PullWatch.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Text="Dashboard" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="14"
                           Style="{StaticResource SecondaryTextStyle}"
                           Text="Recording status and controls" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,0,0,18"
                    Background="#392226"
                    BorderBrush="{StaticResource FailureBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Visibility="{Binding IsFailureVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource FailureBrush}"
                                   FontWeight="SemiBold"
                                   Text="Recorder needs attention" />
                        <TextBlock Margin="0,5,12,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding FailureMessage}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding DismissFailureCommand}"
                            Content="Dismiss" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,18"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="RECORDING STATUS" />
                        <TextBlock Margin="0,7,0,0"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Text="{Binding StateTitle}" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="14"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding StateDescription}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="28,0,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="Duration" />
                        <TextBlock Margin="0,5,0,0"
                                   FontFamily="Consolas"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="{Binding Duration}" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="Activity" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding RecordingDetail}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding RecordingDetail}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                       Text="Output path" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="14"
                                       Text="{Binding OutputPath}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding OutputPath}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="0,28,0,0"
                                Orientation="Horizontal">
                        <Button Command="{Binding ManualRecordingCommand}"
                                Content="{Binding ManualRecordingButtonText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsManualStopMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource FailureBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource FailureBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="10,0,0,0"
                                Command="{Binding OpenRecordingsFolderCommand}"
                                Content="Open recordings folder" />
                        <TextBlock Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding CommandMessage}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,9,0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Combat log" />
                        <TextBlock Margin="0,13,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding CombatLogHealth}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CombatLogHealth}" Value="Monitoring">
                                            <Setter Property="Foreground" Value="{StaticResource HealthyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding CombatLogDetail}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CombatLogDetail}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="9,0,0,0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Recorder" />
                        <TextBlock Margin="0,13,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding RecorderHealth}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource HealthyBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecorderHealth}" Value="Attention needed">
                                            <Setter Property="Foreground" Value="{StaticResource FailureBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecorderHealth}" Value="Idle">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding RecorderDetail}" />
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding RecordingStatistics}"
                                   ToolTip="Expected counts accepted recording requests. Saved counts recordings finalized successfully." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
