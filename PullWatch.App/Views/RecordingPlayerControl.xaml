<UserControl
  x:Class="PullWatch.RecordingPlayerControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <UserControl.Resources>
    <Style
      x:Key="PlayerIconButtonStyle"
      BasedOn="{StaticResource BaseButtonStyle}"
      TargetType="Button"
    >
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Geometry x:Key="PlayIconGeometry">M 5 3 L 12 8 L 5 13 Z</Geometry>
    <Geometry x:Key="StopIconGeometry">M 4 4 L 12 4 L 12 12 L 4 12 Z</Geometry>
    <Geometry x:Key="EnterFullScreenIconGeometry">
      M 1 6 L 1 1 L 6 1 M 10 1 L 15 1 L 15 6 M 1 10 L 1 15 L 6 15 M 10 15 L 15 15 L 15 10
    </Geometry>
    <Geometry x:Key="ExitFullScreenIconGeometry">
      M 6 1 L 6 6 L 1 6 M 10 1 L 10 6 L 15 6 M 1 10 L 6 10 L 6 15 M 15 10 L 10 10 L 10 15
    </Geometry>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Background="{StaticResource PlayerSurfaceBrush}"
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="0,0,0,1"
    >
      <Grid>
        <MediaElement
          x:Name="MediaPlayer"
          LoadedBehavior="Manual"
          MediaEnded="OnPlayerMediaEnded"
          MediaFailed="OnPlayerMediaFailed"
          MediaOpened="OnPlayerMediaOpened"
          ScrubbingEnabled="True"
          Stretch="Uniform"
          UnloadedBehavior="Manual"
        />
        <TextBlock
          x:Name="PlayerPlaceholder"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="14"
          Style="{StaticResource SecondaryTextStyle}"
          TextAlignment="Center"
        />
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="18,12,18,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button
        x:Name="PlayPauseButton"
        Grid.Column="0"
        Click="OnPlayPauseClicked"
        IsEnabled="False"
        Style="{StaticResource PlayerIconButtonStyle}"
        ToolTip="Play"
      >
        <Path
          x:Name="PlayPauseIcon"
          Width="16"
          Height="16"
          Data="{StaticResource PlayIconGeometry}"
          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
          Stretch="Uniform"
        />
      </Button>
      <Slider
        x:Name="PlaybackSlider"
        Grid.Column="1"
        Margin="12,0,0,0"
        VerticalAlignment="Center"
        IsEnabled="False"
        Maximum="0"
        Minimum="0"
        PreviewMouseDown="OnPlaybackSliderPreviewMouseDown"
        PreviewMouseUp="OnPlaybackSliderPreviewMouseUp"
        ValueChanged="OnPlaybackSliderValueChanged"
      />
      <TextBlock
        x:Name="PlaybackTimeText"
        Grid.Column="2"
        MinWidth="104"
        Margin="12,0,0,0"
        VerticalAlignment="Center"
        FontFamily="Consolas"
        Style="{StaticResource SecondaryTextStyle}"
        Text="00:00 / 00:00"
        TextAlignment="Right"
      />
      <Button
        x:Name="FullScreenButton"
        Grid.Column="3"
        Margin="12,0,0,0"
        Click="OnFullScreenClicked"
        IsEnabled="False"
        Style="{StaticResource PlayerIconButtonStyle}"
        ToolTip="Enter fullscreen"
      >
        <Path
          x:Name="FullScreenIcon"
          Width="16"
          Height="16"
          Data="{StaticResource EnterFullScreenIconGeometry}"
          Fill="Transparent"
          SnapsToDevicePixels="True"
          Stretch="Uniform"
          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
          StrokeEndLineCap="Round"
          StrokeLineJoin="Round"
          StrokeStartLineCap="Round"
          StrokeThickness="1.6"
        />
      </Button>
    </Grid>
  </Grid>
</UserControl>
