<Window
  x:Class="PullWatch.WhatsNewWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
  Title="{Binding Heading}"
  Width="620"
  Height="540"
  SizeToContent="Manual"
  Style="{StaticResource DialogWindowStyle}"
  WindowStartupLocation="CenterOwner"
>
  <Border Style="{StaticResource DialogSurfaceStyle}">
    <Grid Margin="28,26,28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
          Grid.Column="0"
          Margin="0,2,18,0"
          FontSize="22"
          FontWeight="SemiBold"
          Text="{Binding Heading}"
          TextWrapping="Wrap"
        />

        <Button
          Grid.Column="1"
          Width="30"
          Height="30"
          Padding="0"
          VerticalAlignment="Top"
          Click="OnCloseClick"
          Style="{StaticResource SidebarIconButtonStyle}"
          ToolTip="Close"
        >
          <Path
            Width="11"
            Height="11"
            Data="{x:Static local:ShellIconGeometries.Close}"
            Stretch="Uniform"
            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
            StrokeEndLineCap="Round"
            StrokeStartLineCap="Round"
            StrokeThickness="1.8"
          />
        </Button>
      </Grid>

      <ScrollViewer
        Grid.Row="1"
        Margin="0,22,0,18"
        HorizontalScrollBarVisibility="Disabled"
        PanningMode="VerticalOnly"
        VerticalScrollBarVisibility="Auto"
      >
        <ItemsControl Margin="0,0,14,0" ItemsSource="{Binding Sections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,24">
                <TextBlock
                  Style="{StaticResource SectionTitleStyle}"
                  Text="{Binding Heading}"
                  TextWrapping="Wrap"
                />

                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Bullets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="18" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                          Grid.Column="0"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Text="•"
                        />
                        <TextBlock
                          Grid.Column="1"
                          Foreground="{StaticResource PrimaryTextBrush}"
                          LineHeight="21"
                          Text="{Binding}"
                          TextWrapping="Wrap"
                        />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Button
        x:Name="GotItButton"
        Grid.Row="2"
        MinWidth="96"
        HorizontalAlignment="Right"
        Click="OnCloseClick"
        Content="Got it"
        IsCancel="True"
        IsDefault="True"
        Style="{StaticResource AccentButtonStyle}"
      />
    </Grid>
  </Border>
</Window>
