<Window
  x:Class="PullWatch.EncoderCalibrationProgressWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Testing Video Encoding"
  Width="440"
  MinWidth="400"
  MaxWidth="520"
  AllowsTransparency="True"
  Background="Transparent"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  WindowStyle="None"
>
  <Border
    Background="{StaticResource WindowBrush}"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="1"
    CornerRadius="8"
    SnapsToDevicePixels="True"
  >
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border
        Grid.Row="0"
        Background="{StaticResource SurfaceBrush}"
        CornerRadius="8,8,0,0"
        MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown"
        Padding="18,14"
      >
        <TextBlock
          VerticalAlignment="Center"
          FontSize="13"
          FontWeight="SemiBold"
          Text="Testing Video Encoding"
          TextTrimming="CharacterEllipsis"
        />
      </Border>

      <Grid Grid.Row="1" Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
          Grid.Row="0"
          FontSize="18"
          FontWeight="SemiBold"
          Text="Testing video encoding"
          TextWrapping="Wrap"
        />

        <TextBlock
          x:Name="StatusTextBlock"
          Grid.Row="1"
          Margin="0,12,0,0"
          Style="{StaticResource SecondaryTextStyle}"
          Text="Preparing encoder tests..."
        />

        <ProgressBar
          x:Name="ProfileProgressBar"
          Grid.Row="2"
          Height="8"
          Margin="0,16,0,0"
          Background="{StaticResource ProgressTrackBrush}"
          BorderBrush="{StaticResource ProgressTrackBorderBrush}"
          BorderThickness="1"
          Foreground="{StaticResource AccentBrush}"
          Maximum="1"
          Minimum="0"
          Value="0"
        >
          <ProgressBar.Template>
            <ControlTemplate TargetType="ProgressBar">
              <Grid SnapsToDevicePixels="True">
                <Border
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="3"
                />
                <Grid Margin="1" ClipToBounds="True">
                  <Border x:Name="PART_Track" Background="Transparent" />
                  <Border
                    x:Name="PART_Indicator"
                    HorizontalAlignment="Left"
                    Background="{TemplateBinding Foreground}"
                    CornerRadius="2"
                  />
                </Grid>
              </Grid>
            </ControlTemplate>
          </ProgressBar.Template>
        </ProgressBar>

        <TextBlock
          x:Name="StepTextBlock"
          Grid.Row="3"
          Margin="0,8,0,0"
          HorizontalAlignment="Right"
          Style="{StaticResource SecondaryTextStyle}"
          Text="0 of 6"
        />
      </Grid>
    </Grid>
  </Border>
</Window>
