<UserControl
  x:Class="PullWatch.RecordingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Margin="18"
      Background="{StaticResource WarningSurfaceBrush}"
      BorderBrush="{StaticResource FailureBrush}"
      BorderThickness="1"
      CornerRadius="8"
      Padding="16"
      Visibility="{Binding IsFailureVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
            Foreground="{StaticResource FailureBrush}"
            FontWeight="SemiBold"
            Text="Recorder needs attention"
          />
          <TextBlock
            Margin="0,5,12,0"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding FailureMessage}"
          />
        </StackPanel>

        <Button Grid.Column="1" Command="{Binding DismissFailureCommand}" Content="Dismiss" />
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="320" />
        <RowDefinition Height="18" />
        <RowDefinition Height="190" MinHeight="190" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <ContentControl x:Name="PlayerHost">
          <local:RecordingPlayerControl
            x:Name="RecordingPlayer"
            PlaceholderText="{Binding RecordingLibraryStatus}"
            Source="{Binding SelectedRecording.Source}"
          />
        </ContentControl>
      </Grid>

      <GridSplitter
        x:Name="PlayerListSplitter"
        Grid.Row="1"
        Height="18"
        Margin="0,10,0,0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Style="{StaticResource SplitterGripStyle}"
      />

      <Grid Grid.Row="2" Margin="18,0,18,18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <ListBox
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding RecordingCategories}"
            SelectedItem="{Binding SelectedRecordingCategory, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
          >
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <TextBlock
                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                    Text="{Binding Title}"
                    TextWrapping="NoWrap"
                  />
                  <TextBlock
                    Margin="6,0,0,0"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="{Binding Count}"
                    TextWrapping="NoWrap"
                  />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Grid>
                        <Border
                          x:Name="TabBorder"
                          Background="{StaticResource SurfaceRaisedBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="{TemplateBinding Padding}"
                        >
                          <ContentPresenter />
                        </Border>
                        <Border
                          x:Name="TabFocusBorder"
                          BorderBrush="{StaticResource FocusBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          IsHitTestVisible="False"
                          Opacity="0"
                        />
                      </Grid>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter
                            TargetName="TabBorder"
                            Property="Background"
                            Value="{StaticResource ListItemHoverBrush}"
                          />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter
                            TargetName="TabBorder"
                            Property="Background"
                            Value="{StaticResource SelectedSurfaceBrush}"
                          />
                          <Setter
                            TargetName="TabBorder"
                            Property="BorderBrush"
                            Value="{StaticResource AccentBrush}"
                          />
                          <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                          <Setter TargetName="TabFocusBorder" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter Property="Opacity" Value="0.45" />
                          <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>

          <Button
            Grid.Column="1"
            Command="{Binding OpenRecordingsFolderCommand}"
            Content="Open folder"
          />
          <Button
            Grid.Column="2"
            Margin="8,0,0,0"
            Command="{Binding DeleteSelectedRecordingCommand}"
            Style="{StaticResource StopButtonStyle}"
            ToolTip="Delete selected recording"
          >
            <StackPanel Orientation="Horizontal">
              <Path
                Width="14"
                Height="14"
                Margin="0,0,7,0"
                VerticalAlignment="Center"
                Data="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"
                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Stretch="Uniform"
              />
              <TextBlock
                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Text="Delete"
              />
            </StackPanel>
          </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="15,0,15,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="132" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{Binding ContextColumnWidth}" />
            <ColumnDefinition Width="{Binding ResultColumnWidth}" />
            <ColumnDefinition Width="{Binding DurationColumnWidth}" />
            <ColumnDefinition Width="{Binding ScrollBarColumnWidth}" />
          </Grid.ColumnDefinitions>

          <TextBlock
            Grid.Column="0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Started"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="1"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding ActivityColumnHeader}"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="2"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding ContextColumnHeader}"
            TextWrapping="NoWrap"
            Visibility="{Binding IsContextColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
          />
          <TextBlock
            Grid.Column="3"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding ResultColumnHeader}"
            TextWrapping="NoWrap"
            Visibility="{Binding IsResultColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
          />
          <TextBlock
            Grid.Column="4"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding DurationColumnHeader}"
            TextAlignment="Right"
            TextWrapping="NoWrap"
            Visibility="{Binding IsDurationColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
          />
        </Grid>

        <ListBox
          Grid.Row="2"
          Background="{StaticResource SurfaceRaisedBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          Foreground="{StaticResource PrimaryTextBrush}"
          ItemsSource="{Binding Recordings}"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Visible"
          SelectedItem="{Binding SelectedRecording, Mode=TwoWay}"
        >
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="4" ToolTip="{Binding ToolTip}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="132" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="{Binding ContextColumnWidth}" />
                  <ColumnDefinition Width="{Binding ResultColumnWidth}" />
                  <ColumnDefinition Width="{Binding DurationColumnWidth}" />
                </Grid.ColumnDefinitions>

                <TextBlock
                  Grid.Column="0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding StartedAt}"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="1"
                  Margin="14,0,0,0"
                  FontWeight="SemiBold"
                  Text="{Binding Activity}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="2"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding Context}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                  Visibility="{Binding IsContextVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                />
                <TextBlock
                  Grid.Column="3"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding Result}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                  Visibility="{Binding IsResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                />
                <TextBlock
                  Grid.Column="4"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding Duration}"
                  TextAlignment="Right"
                  TextWrapping="NoWrap"
                  Visibility="{Binding IsDurationVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="SelectableListItemStyle" />
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
