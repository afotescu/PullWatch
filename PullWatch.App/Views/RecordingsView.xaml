<UserControl x:Class="PullWatch.RecordingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Background="#392226"
                BorderBrush="{StaticResource FailureBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Visibility="{Binding IsFailureVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Foreground="{StaticResource FailureBrush}"
                               FontWeight="SemiBold"
                               Text="Recorder needs attention" />
                    <TextBlock Margin="0,5,12,0"
                               Style="{StaticResource SecondaryTextStyle}"
                               Text="{Binding FailureMessage}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding DismissFailureCommand}"
                        Content="Dismiss" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="320" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="2*" MinHeight="190" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#111318"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <MediaElement x:Name="RecordingPlayer"
                                          LoadedBehavior="Manual"
                                          MediaEnded="OnPlayerMediaEnded"
                                          MediaFailed="OnPlayerMediaFailed"
                                          MediaOpened="OnPlayerMediaOpened"
                                          ScrubbingEnabled="True"
                                          Stretch="Uniform"
                                          UnloadedBehavior="Stop" />
                            <TextBlock x:Name="PlayerPlaceholder"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="{Binding RecordingLibraryStatus}"
                                       TextAlignment="Center"
                                       Visibility="{Binding IsPlayerPlaceholderVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PlayPauseButton"
                                Grid.Column="0"
                                MinWidth="72"
                                Click="OnPlayPauseClicked"
                                Content="Play"
                                IsEnabled="False" />
                        <Slider x:Name="PlaybackSlider"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                IsEnabled="False"
                                Maximum="0"
                                Minimum="0"
                                PreviewMouseDown="OnPlaybackSliderPreviewMouseDown"
                                PreviewMouseUp="OnPlaybackSliderPreviewMouseUp"
                                ValueChanged="OnPlaybackSliderValueChanged" />
                        <TextBlock x:Name="PlaybackTimeText"
                                   Grid.Column="2"
                                   MinWidth="104"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="00:00 / 00:00"
                                   TextAlignment="Right" />
                    </Grid>
                </Grid>

                <GridSplitter x:Name="PlayerListSplitter"
                              Grid.Row="1"
                              Height="18"
                              Margin="0,10,0,0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeNS"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Rows">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="Transparent">
                                <Border Width="50"
                                        Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SecondaryTextBrush}"
                                        CornerRadius="5" />
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,10,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Saved recordings" />
                        <Button Grid.Column="1"
                                Command="{Binding OpenRecordingsFolderCommand}"
                                Content="Open folder" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             Background="{StaticResource SurfaceRaisedBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             ItemsSource="{Binding Recordings}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectedItem="{Binding SelectedRecording, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding DisplayName}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontSize="12"
                                               Style="{StaticResource SecondaryTextStyle}"
                                               Text="{Binding Detail}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8" />
                                <Setter Property="Margin" Value="3" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder"
                                                            Property="Background"
                                                            Value="#343B45" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder"
                                                            Property="Background"
                                                            Value="#3A3024" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
