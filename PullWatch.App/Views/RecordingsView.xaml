<UserControl
  x:Class="PullWatch.RecordingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Margin="18"
      Background="{StaticResource WarningSurfaceBrush}"
      BorderBrush="{StaticResource FailureBrush}"
      BorderThickness="1"
      CornerRadius="8"
      Padding="16"
      Visibility="{Binding IsFailureVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
            Foreground="{StaticResource FailureBrush}"
            FontWeight="SemiBold"
            Text="Recorder needs attention"
          />
          <TextBlock
            Margin="0,5,12,0"
            Style="{StaticResource SecondaryTextStyle}"
            Text="{Binding FailureMessage}"
          />
        </StackPanel>

        <Button Grid.Column="1" Command="{Binding DismissFailureCommand}" Content="Dismiss" />
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="320" />
        <RowDefinition Height="18" />
        <RowDefinition Height="190" MinHeight="190" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <ContentControl x:Name="PlayerHost">
          <local:RecordingPlayerControl
            x:Name="RecordingPlayer"
            PlaceholderText="{Binding RecordingLibraryStatus}"
            Source="{Binding SelectedRecording.Source}"
          />
        </ContentControl>
      </Grid>

      <GridSplitter
        x:Name="PlayerListSplitter"
        Grid.Row="1"
        Height="18"
        Margin="0,10,0,0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Style="{StaticResource SplitterGripStyle}"
      />

      <Grid Grid.Row="2" Margin="18,0,18,18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,10,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock FontWeight="SemiBold" Text="Saved recordings" />
            <TextBlock
              Margin="0,3,12,0"
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding CommandMessage}"
              Visibility="{Binding IsCommandMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            />
          </StackPanel>
          <Button
            Grid.Column="1"
            Command="{Binding OpenRecordingsFolderCommand}"
            Content="Open folder"
          />
          <Button
            Grid.Column="2"
            Margin="8,0,0,0"
            Command="{Binding DeleteSelectedRecordingCommand}"
            Style="{StaticResource StopButtonStyle}"
            ToolTip="Delete selected recording"
          >
            <StackPanel Orientation="Horizontal">
              <TextBlock
                Margin="0,0,7,0"
                FontFamily="Segoe MDL2 Assets"
                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Text="&#xE74D;"
              />
              <TextBlock
                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Text="Delete"
              />
            </StackPanel>
          </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="15,0,15,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="132" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="92" />
            <ColumnDefinition Width="108" />
          </Grid.ColumnDefinitions>

          <TextBlock
            Grid.Column="0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Started"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="1"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Encounter"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="2"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Difficulty"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="3"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Outcome"
            TextWrapping="NoWrap"
          />
          <TextBlock
            Grid.Column="4"
            Margin="14,0,0,0"
            FontSize="11"
            FontWeight="SemiBold"
            Style="{StaticResource SecondaryTextStyle}"
            Text="Duration"
            TextAlignment="Right"
            TextWrapping="NoWrap"
          />
        </Grid>

        <ListBox
          Grid.Row="2"
          Background="{StaticResource SurfaceRaisedBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          Foreground="{StaticResource PrimaryTextBrush}"
          ItemsSource="{Binding Recordings}"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          SelectedItem="{Binding SelectedRecording, Mode=TwoWay}"
        >
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="4" ToolTip="{Binding ToolTip}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="132" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="92" />
                  <ColumnDefinition Width="108" />
                </Grid.ColumnDefinitions>

                <TextBlock
                  Grid.Column="0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding StartedAt}"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="1"
                  Margin="14,0,0,0"
                  FontWeight="SemiBold"
                  Text="{Binding EncounterName}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="2"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding Difficulty}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="3"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding Outcome}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                />
                <TextBlock
                  Grid.Column="4"
                  Margin="14,0,0,0"
                  FontSize="12"
                  Style="{StaticResource SecondaryTextStyle}"
                  Text="{Binding FightDuration}"
                  TextAlignment="Right"
                  TextWrapping="NoWrap"
                />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="SelectableListItemStyle" />
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
