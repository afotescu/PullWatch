<Window
  x:Class="PullWatch.ConfirmationDialogWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="PullWatch"
  Width="480"
  MinWidth="420"
  MaxWidth="560"
  AllowsTransparency="True"
  Background="Transparent"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  WindowStyle="None"
>
  <Border
    Background="{StaticResource WindowBrush}"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="1"
    CornerRadius="8"
    SnapsToDevicePixels="True"
  >
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock
            x:Name="TitleTextBlock"
            Grid.Column="0"
            Margin="0,2,18,0"
            FontSize="18"
            FontWeight="SemiBold"
            TextWrapping="Wrap"
          />

          <Button
            Grid.Column="1"
            Width="30"
            Height="30"
            Padding="0"
            VerticalAlignment="Top"
            Click="OnCloseClick"
            Style="{StaticResource SidebarIconButtonStyle}"
          >
            <Path
              Width="11"
              Height="11"
              Data="M 1 1 L 10 10 M 10 1 L 1 10"
              Stretch="Uniform"
              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
              StrokeEndLineCap="Round"
              StrokeStartLineCap="Round"
              StrokeThickness="1.8"
            />
          </Button>
        </Grid>

        <ItemsControl x:Name="MessageItemsControl" Grid.Row="1" Margin="0,14,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SecondaryTextStyle}"
                Text="{Binding}"
              />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel
          x:Name="ButtonsPanel"
          Grid.Row="2"
          Margin="0,18,0,0"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
        />
      </Grid>
    </Grid>
  </Border>
</Window>
