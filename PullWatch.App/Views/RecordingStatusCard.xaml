<UserControl
  x:Class="PullWatch.RecordingStatusCard"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
>
  <UserControl.Resources>
    <Style x:Key="StatusBorderStyle" TargetType="Border">
      <Setter Property="BorderBrush" Value="{StaticResource StatusNeutralBrush}" />
      <Style.Triggers>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.Active}"
        >
          <Setter Property="BorderBrush" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.Ready}"
        >
          <Setter Property="BorderBrush" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.ManualOnly}"
        >
          <Setter Property="BorderBrush" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.AttentionNeeded}"
        >
          <Setter Property="BorderBrush" Value="{StaticResource FailureBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
      <Setter Property="Fill" Value="{StaticResource StatusNeutralBrush}" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.Active}"
        >
          <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.Ready}"
        >
          <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.ManualOnly}"
        >
          <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding StatusHealth}"
          Value="{x:Static local:RecordingStatusHealth.AttentionNeeded}"
        >
          <Setter Property="Fill" Value="{StaticResource FailureBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsRecordingPulseActive}" Value="True">
          <Setter Property="Fill" Value="{StaticResource HealthyBrush}" />
          <DataTrigger.EnterActions>
            <BeginStoryboard x:Name="RecordingPulseStoryboard">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation
                  Storyboard.TargetProperty="Opacity"
                  To="0.48"
                  Duration="0:0:0.75"
                />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                  To="1.18"
                  Duration="0:0:0.75"
                />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                  To="1.18"
                  Duration="0:0:0.75"
                />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <StopStoryboard BeginStoryboardName="RecordingPulseStoryboard" />
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Border
    Background="{StaticResource SurfaceBrush}"
    BorderThickness="1"
    CornerRadius="8"
    Padding="14"
    Style="{StaticResource StatusBorderStyle}"
    ToolTip="{Binding ReadinessDetail}"
    ToolTipService.InitialShowDelay="250"
    ToolTipService.ShowDuration="12000"
  >
    <StackPanel>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Ellipse
          Grid.Column="0"
          Width="9"
          Height="9"
          Margin="0,5,8,0"
          Style="{StaticResource StatusIndicatorStyle}"
        />

        <StackPanel Grid.Column="1">
          <TextBlock
            FontSize="13"
            FontWeight="SemiBold"
            Text="{Binding StateTitle}"
            TextTrimming="CharacterEllipsis"
          />
          <TextBlock
            Margin="0,4,0,0"
            FontFamily="Consolas"
            FontSize="22"
            FontWeight="SemiBold"
            Text="{Binding Duration}"
          />
        </StackPanel>
      </Grid>

      <Button
        Margin="0,16,0,0"
        HorizontalAlignment="Stretch"
        Command="{Binding ManualRecordingCommand}"
        Content="{Binding ManualRecordingButtonText}"
      >
        <Button.Style>
          <Style TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsManualStopMode}" Value="True">
                <Setter Property="Background" Value="{StaticResource FailureBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource FailureBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>
    </StackPanel>
  </Border>
</UserControl>
