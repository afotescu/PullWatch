<Window
  x:Class="PullWatch.MainWindow"
  x:Name="ShellWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:PullWatch"
  Title="PullWatch"
  Width="1180"
  Height="760"
  MinWidth="900"
  MinHeight="600"
  Icon="Assets/favicon.ico"
  WindowStartupLocation="CenterScreen"
>
  <Window.Resources>
    <Style x:Key="CollapsedStatusButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Background="Transparent">
              <Border
                x:Name="HoverBackground"
                Background="{StaticResource SurfaceRaisedBrush}"
                CornerRadius="6"
                Opacity="0"
              />
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Border
                x:Name="FocusBorder"
                BorderBrush="{StaticResource FocusBrush}"
                BorderThickness="1"
                CornerRadius="6"
                IsHitTestVisible="False"
                Opacity="0"
              />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="HoverBackground" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="FocusBorder" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style
      x:Key="SidebarUpdateButtonStyle"
      BasedOn="{StaticResource BaseButtonStyle}"
      TargetType="Button"
    >
      <Setter Property="MaxWidth" Value="190" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Updates.IsActionProminent}" Value="True">
          <Setter Property="Background" Value="{StaticResource AccentBrush}" />
          <Setter Property="Foreground" Value="{StaticResource FilledButtonTextBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
          <Setter
            Property="local:ButtonChrome.HoverOverlayBrush"
            Value="{StaticResource FilledButtonHoverOverlayBrush}"
          />
          <Setter
            Property="local:ButtonChrome.PressedOverlayBrush"
            Value="{StaticResource FilledButtonPressedOverlayBrush}"
          />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style
      x:Key="NotificationActionButtonStyle"
      BasedOn="{StaticResource AccentButtonStyle}"
      TargetType="Button"
    >
      <Setter Property="MinWidth" Value="122" />
      <Setter Property="MaxWidth" Value="180" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style
      x:Key="NotificationDismissButtonStyle"
      BasedOn="{StaticResource BaseButtonStyle}"
      TargetType="Button"
    >
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="ToolTip" Value="Dismiss" />
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource WindowBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding DataContext.SidebarWidth, ElementName=ShellWindow}" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border
      Grid.Column="0"
      Background="{StaticResource SidebarBrush}"
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="0,0,1,0"
    >
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Padding" Value="20,24" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
              <Setter Property="Padding" Value="10,24" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>

      <Grid>
        <DockPanel Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel DockPanel.Dock="Top">
            <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
              <Image
                Width="26"
                Height="26"
                Margin="0,2,10,0"
                RenderOptions.BitmapScalingMode="HighQuality"
                Source="Assets/favicon.ico"
              />
              <TextBlock FontSize="26" FontWeight="SemiBold" Text="PullWatch" />
            </StackPanel>

            <local:RecordingStatusCard Margin="0,0,0,22" DataContext="{Binding Recordings}" />
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
            <Button
              Margin="0,0,0,8"
              HorizontalAlignment="Left"
              Command="{Binding Updates.UpdateCommand}"
              Style="{StaticResource SidebarUpdateButtonStyle}"
              ToolTip="{Binding Updates.ActionToolTip}"
            >
              <TextBlock
                Text="{Binding Updates.ActionText}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
              />
            </Button>
            <TextBlock
              Margin="0,0,0,8"
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding Updates.StatusMessage}"
              Visibility="{Binding Updates.IsStatusMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            />
            <TextBlock
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding AppVersionLabel}"
            />
            <Button
              Margin="0,14,0,0"
              HorizontalAlignment="Left"
              Command="{Binding ToggleSidebarCommand}"
              Style="{StaticResource SidebarIconButtonStyle}"
              ToolTip="{Binding SidebarToggleToolTip}"
            >
              <Path
                Width="13"
                Height="13"
                Data="{Binding SidebarToggleIcon}"
                Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeEndLineCap="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="1.8"
              />
            </Button>
          </StackPanel>

          <ListBox
            ItemsSource="{Binding NavigationItems}"
            SelectedItem="{Binding SelectedNavigationItem}"
            Style="{StaticResource NavigationListStyle}"
            ItemContainerStyle="{StaticResource NavigationItemStyle}"
          >
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,12,0"
                    Data="{Binding Icon}"
                    Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                    Stretch="Uniform"
                  />
                  <TextBlock
                    FontSize="14"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                    Text="{Binding Title}"
                  />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>

        <DockPanel Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel
            DockPanel.Dock="Top"
            Width="44"
            Margin="0,0,0,22"
            HorizontalAlignment="Center"
          >
            <Image
              Width="30"
              Height="30"
              Margin="0,2,0,28"
              HorizontalAlignment="Center"
              RenderOptions.BitmapScalingMode="HighQuality"
              Source="Assets/favicon.ico"
              ToolTip="PullWatch"
            />

            <Button
              Command="{Binding Recordings.ManualRecordingCommand}"
              Style="{StaticResource CollapsedStatusButtonStyle}"
              ToolTip="{Binding Recordings.CollapsedStatusToolTip}"
              ToolTipService.InitialShowDelay="250"
              ToolTipService.ShowDuration="12000"
            >
              <local:RecordingStatusIndicator
                Width="18"
                Height="18"
                HorizontalAlignment="Center"
                Health="{Binding Recordings.StatusHealth}"
                IndicatorStrokeThickness="1"
                IsPulseActive="{Binding Recordings.IsRecordingPulseActive}"
              />
            </Button>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center">
            <Button
              Margin="0,0,0,8"
              HorizontalAlignment="Center"
              Command="{Binding Updates.UpdateCommand}"
              Style="{StaticResource SidebarUpdateButtonStyle}"
              ToolTip="{Binding Updates.ActionToolTip}"
              ToolTipService.ShowOnDisabled="True"
            >
              <Path
                Width="15"
                Height="15"
                Data="{Binding Updates.ActionIcon}"
                Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="1.8"
              />
            </Button>
            <TextBlock
              Margin="0,0,0,10"
              HorizontalAlignment="Center"
              FontSize="10"
              Style="{StaticResource SecondaryTextStyle}"
              Text="{Binding AppVersion}"
              TextAlignment="Center"
              TextWrapping="NoWrap"
              ToolTip="{Binding AppVersionLabel}"
            />
            <Button
              Command="{Binding ToggleSidebarCommand}"
              Style="{StaticResource SidebarIconButtonStyle}"
              ToolTip="{Binding SidebarToggleToolTip}"
            >
              <Path
                Width="13"
                Height="13"
                Data="{Binding SidebarToggleIcon}"
                Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeEndLineCap="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="1.8"
              />
            </Button>
          </StackPanel>

          <ListBox
            HorizontalAlignment="Center"
            ItemsSource="{Binding NavigationItems}"
            SelectedItem="{Binding SelectedNavigationItem}"
            Style="{StaticResource NavigationListStyle}"
            ItemContainerStyle="{StaticResource CollapsedNavigationItemStyle}"
          >
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Path
                  Width="18"
                  Height="18"
                  Data="{Binding Icon}"
                  Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                  Stretch="Uniform"
                />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ItemsControl
        Grid.Row="0"
        Margin="18,18,18,0"
        ItemsSource="{Binding Notifications.Items}"
        Visibility="{Binding Notifications.HasNotifications, Converter={StaticResource BooleanToVisibilityConverter}}"
      >
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type local:NotificationViewModel}">
            <Border
              Margin="0,0,0,10"
              Background="{StaticResource SurfaceRaisedBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="0"
            >
              <Grid MinHeight="72">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="4" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="7,0,0,7">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger
                          Binding="{Binding Severity}"
                          Value="{x:Static local:NotificationSeverity.Success}"
                        >
                          <Setter Property="Background" Value="{StaticResource HealthyBrush}" />
                        </DataTrigger>
                        <DataTrigger
                          Binding="{Binding Severity}"
                          Value="{x:Static local:NotificationSeverity.Warning}"
                        >
                          <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger
                          Binding="{Binding Severity}"
                          Value="{x:Static local:NotificationSeverity.Error}"
                        >
                          <Setter Property="Background" Value="{StaticResource FailureBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,13,18,13" VerticalAlignment="Center">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock
                    Margin="0,4,0,0"
                    Style="{StaticResource SecondaryTextStyle}"
                    Text="{Binding Message}"
                  />
                </StackPanel>

                <Button
                  Grid.Column="2"
                  Margin="0,0,14,0"
                  Command="{Binding ActionCommand}"
                  Style="{StaticResource NotificationActionButtonStyle}"
                  Visibility="{Binding IsActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                >
                  <TextBlock
                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Text="{Binding ActionText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                  />
                </Button>

                <Button
                  Grid.Column="3"
                  Margin="0,0,14,0"
                  Command="{Binding DismissCommand}"
                  Style="{StaticResource NotificationDismissButtonStyle}"
                  Visibility="{Binding IsDismissVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                >
                  <Path
                    Width="12"
                    Height="12"
                    Data="{x:Static local:ShellIconGeometries.Close}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeEndLineCap="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="1.8"
                  />
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ContentControl Grid.Row="1" Content="{Binding SelectedNavigationItem.Content}" />
    </Grid>
  </Grid>
</Window>
